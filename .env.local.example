GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
GITHUB_TOKEN=
# OpenRouter (https://openrouter.ai/keys) — 1 key mở khóa 50+ free models (DeepSeek V3, Llama 3.3, Qwen 2.5 72B...).
OPENROUTER_API_KEY=
# Cerebras (https://cloud.cerebras.ai/platform/api-keys) — inference >2000 t/s, free 14,400 RPD.
CEREBRAS_API_KEY=
# Mistral La Plateforme (https://console.mistral.ai/api-keys) — Codestral + Ministral, free 1B tokens/tháng.
MISTRAL_API_KEY=
BRAVE_SEARCH_API_KEY=

# === Cloud Sync (optional) ===
# Đăng ký GitHub OAuth App tại: https://github.com/settings/developers
# - Homepage URL: https://your-deploy.example.com
# - Authorization callback URL: https://your-deploy.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth — sinh secret bằng: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-deploy.example.com

# Upstash Redis — đăng ký tại https://console.upstash.com (free tier 10K cmds/day)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
