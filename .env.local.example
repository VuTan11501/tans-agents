GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
GITHUB_TOKEN=
BRAVE_SEARCH_API_KEY=

# === Cloud Sync (optional) ===
# Đăng ký GitHub OAuth App tại: https://github.com/settings/developers
# - Homepage URL: https://your-deploy.example.com
# - Authorization callback URL: https://your-deploy.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth — sinh secret bằng: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-deploy.example.com

# Upstash Redis — đăng ký tại https://console.upstash.com (free tier 10K cmds/day)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
